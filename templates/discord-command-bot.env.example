# Copy to ~/.config/ignition/discord-command-bot.env and fill in your values.
DISCORD_BOT_TOKEN=discord_bot_token_here
# Restrict the bot to one or more Discord channel IDs.
DISCORD_ALLOWED_CHANNELS=123456789012345678
# Optional: restrict to specific user IDs.
# DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432
IGNITION_REPO_ROOT=/home/mei/Documents/ignition
